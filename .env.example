# Database Configuration (Optional)
# Required for pgvector integration with PostgreSQL
# Leave empty to use local in-memory vector store only
DATABASE_URL=postgresql://user:password@host:port/database

# Example Neon Database connection string:
# DATABASE_URL=postgresql://username:password@ep-cool-neon-host.us-east-2.aws.neon.tech/neondb?sslmode=require

# Advanced Feature Flags (Optional)

# Enable local transformer embeddings (disabled by default due to protobufjs CVE)
# Set to 'true' to enable @xenova/transformers model for real embeddings
# If disabled or fails, falls back to hash-based pseudo-embeddings
ENABLE_LOCAL_EMBEDDINGS=false

# Enable OCR for image text extraction (disabled by default due to performance impact)
# Set to 'true' to enable Tesseract.js OCR
ENABLE_OCR=false
